{
    "version": "2",
    "hooks": {
        "post-commit": {
            "name": "Post-commit hooks",
            "actions": {
                "ClangFmt": {
                    "type": "shell",
                    "name": "Clang Format",
                    "runType": "perFile",
                    "priority": 0,
                    "filePattern": "\\.(c|cc|h|hh|cpp|hpp)$", 
                    "shellCmd": ["clang-format", "-style=file", "-i", "<file>"]
                },
                "ClangTidy": {
                    "type": "shell",
                    "name": "Clang Tidy",
                    "runType": "perFile",
                    "priority": 0,
                    "filePattern": "\\.(c|cc|h|hh|cpp|hpp)$", 
                    "shellCmd": ["clang-tidy", "-format-style=file", "--fix", "<file>"]
                },
                "GoFmt": {
                    "type": "shell",
                    "name": "Golang Format",
                    "runType": "perFile",
                    "priority": 0,
                    "filePattern": "\\.go$", 
                    "shellCmd": ["gofmt", "-w", "<file>"]
                },
                "GoVet": {
                    "type": "shell",
                    "name": "Golang Tidy",
                    "runType": "perCommit",
                    "priority": 0,
                    "filePattern": "\\.go$", 
                    "shellCmd": ["go", "vet"]
                },
                "GoModTidy": {
                    "type": "shell",
                    "name": "Golang Module Tidy",
                    "runType": "perCommit",
                    "priority": 0,
                    "filePattern": "^\\.\\/go.mod$", 
                    "shellCmd": ["go", "mod", "tidy"]
                },
                "JavaImportFmt": {
                    "type": "shell",
                    "name": "Java Import Format",
                    "runType": "perFile",
                    "priority": 0,
                    "filePattern": "\\.java$", 
                    "shellCmd": ["google-java-format", "-a", "-r", "--skip-sorting-imports", "--fix-imports-only", "<file>"]
                },
                "JavaFmt": {
                    "type": "shell",
                    "name": "Java Format",
                    "runType": "perFile",
                    "priority": 0,
                    "filePattern": "\\.java$", 
                    "shellCmd": ["google-java-format", "-a", "-r", "--skip-sorting-imports", "<file>"]
                },
                "PythonFmt": {
                    "type": "shell",
                    "name": "Python Format",
                    "runType": "perFile",
                    "priority": 0,
                    "filePattern": "\\.py$", 
                    "shellCmd": ["black", "-q", "-t", "py310", "<file>"]
                },
                "RustFmt": {
                    "type": "shell",
                    "name": "Rust Format",
                    "runType": "perFile",
                    "priority": 0,
                    "filePattern": "\\.rs$", 
                    "shellCmd": ["rustfmt", "<file>", "--edition=2021"]
                },
                "RustTidy": {
                    "type": "shell",
                    "name": "Rust Tidy",
                    "runType": "perCommit",
                    "priority": 0,
                    "filePattern": "\\.rs$", 
                    "shellCmd": ["cargo", "fix", "--allow-dirty"]
                },
                "AndroidXmlFmt": {
                    "type": "androidResourceFormatter"
                }
            }
        },
        "commit-msg": {
            "name": "Edit Commit Message hooks",
            "actions": {
                "Submodule": {
                    "type": "submodule"
                },
                "GerritChangeIdNew": {
                    "type": "gerrit"
                }
            }
        }
    }
}
